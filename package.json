{
  "name": "luma",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "type-check": "tsc -b",
    "format": "prettier --write .",
    "lint:fix": "eslint . --fix",
    "prepare": "husky install"
